# JungAgent instance identity
INSTANCE_NAME=JungAgent
AGENT_INSTANCE=jung_v1
INSTANCE_TIMEZONE=America/Sao_Paulo

# Central admin for this single installation.
# For new Telegram-only instances, prefer ADMIN_PLATFORM_ID and leave
# ADMIN_USER_ID empty so it is derived as sha256(ADMIN_PLATFORM_ID)[:16].
# Only set ADMIN_USER_ID directly when migrating an existing instance.
ADMIN_USER_ID=
ADMIN_PLATFORM=telegram
ADMIN_PLATFORM_ID=
TELEGRAM_ADMIN_IDS=

# Runtime behavior
PROACTIVE_ENABLED=true
ACTIVE_CONSCIOUSNESS_ENABLED=true
ENABLE_UNSAFE_ADMIN_ENDPOINTS=false
WORK_AUTONOMY_ENABLED=true
WORK_MAX_AUTONOMOUS_ACTIONS_PER_DAY=3
WORK_MAX_PENDING_TICKETS=3
WORK_NOTIFY_ADMIN_ON_TICKETS=true

# Optional deep web reading for saber overflow and Work research.
# Keep disabled until FIRECRAWL_API_KEY is configured.
FIRECRAWL_ENABLED=false
FIRECRAWL_API_KEY=
FIRECRAWL_MAX_PAGES_PER_RELEASE=3
FIRECRAWL_TIMEOUT_SECONDS=30
FIRECRAWL_STORE_RAW_CONTENT=false
FIRECRAWL_MAX_MARKDOWN_CHARS=6000

# Telegram
TELEGRAM_BOT_TOKEN=

# LLM providers
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
CONVERSATION_MODEL=z-ai/glm-5
INTERNAL_MODEL=z-ai/glm-5

# Semantic memory via mem0 + Qdrant.
# Recommended for production installs. Use one collection per JungAgent instance.
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=jung_memories_jung_v1
MEM0_LLM_MODEL=openai/gpt-4o-mini
MEM0_LLM_BASE_URL=https://openrouter.ai/api/v1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_BASE_URL=

# Persistence
SQLITE_DB_PATH=
DATABASE_URL=

# Legacy/local semantic memory fallback.
# Production installs should prefer Qdrant above.
CHROMA_DB_PATH=
