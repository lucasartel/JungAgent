# JungAgent instance identity
INSTANCE_NAME=JungAgent
AGENT_INSTANCE=jung_v1
INSTANCE_TIMEZONE=America/Sao_Paulo

# Central admin for this single installation.
# Prefer setting ADMIN_USER_ID for existing instances.
# For new Telegram-only instances, ADMIN_PLATFORM_ID can be set and ADMIN_USER_ID
# will be derived as sha256(ADMIN_PLATFORM_ID)[:16].
ADMIN_USER_ID=
ADMIN_PLATFORM=telegram
ADMIN_PLATFORM_ID=
TELEGRAM_ADMIN_IDS=

# Runtime behavior
PROACTIVE_ENABLED=true
ACTIVE_CONSCIOUSNESS_ENABLED=true
ENABLE_UNSAFE_ADMIN_ENDPOINTS=false

# Telegram
TELEGRAM_BOT_TOKEN=

# LLM providers
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
CONVERSATION_MODEL=z-ai/glm-5
INTERNAL_MODEL=z-ai/glm-5

# Persistence
SQLITE_DB_PATH=
CHROMA_DB_PATH=
DATABASE_URL=
